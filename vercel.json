{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": ["gru1"],
  "functions": {
    "pages/api/games.js": { "maxDuration": 30 },
    "pages/api/cron.js":  { "maxDuration": 30 }
  },
  "crons": [
    {
      "path":     "/api/cron",
      "schedule": "*/5 * * * *"
    }
  ]
}
